---
import { Image } from "astro:assets";
import type { HeroBlock } from "../types/strapi";
import { mediaUrl } from "../lib/strapi";
import Button from "./ui/Button.astro";

interface Props {
  block: HeroBlock;
}

const { block } = Astro.props;
const img = mediaUrl(block.image);
const width = block.image?.width ?? undefined;
const height = block.image?.height ?? undefined;
const hasImage = Boolean(img && width && height);
---

{/* Full-bleed hero: background image spans the whole area, including the
    transparent header (logo + navbar) that floats over it. */}
<section
  class:list={[
    "relative isolate overflow-hidden",
    hasImage ? "bg-primary" : "bg-gradient-to-br from-primary to-accent",
  ]}
>
  {
    hasImage && (
      <>
        <Image
          src={img!}
          width={width!}
          height={height!}
          alt={block.image?.alternativeText ?? ""}
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 -z-10 h-full w-full object-cover"
        />
        {/* Contrast overlay for legible text over the photo. */}
        <div class="absolute inset-0 -z-10 bg-gradient-to-r from-primary/95 via-primary/75 to-primary/35" />
      </>
    )
  }

  {/* Top padding clears the absolute header; bottom padding sets hero height. */}
  <div class="mx-auto max-w-7xl px-4 pb-24 pt-32 sm:px-6 lg:pb-40 lg:pt-44">
    <div class="max-w-2xl">
      <h1 class="font-serif text-4xl font-bold leading-[1.05] tracking-tight text-primary-foreground sm:text-5xl lg:text-6xl">
        {block.title}
      </h1>
      {
        block.subtitle && (
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-primary-foreground/85">
            {block.subtitle}
          </p>
        )
      }
      {
        block.buttonText && block.buttonLink && (
          <div class="mt-8">
            <Button href={block.buttonLink} variant="primary">
              {block.buttonText}
            </Button>
          </div>
        )
      }
    </div>
  </div>
</section>
