---
import type { FeaturedServicesBlock } from "../types/strapi";
import { mediaUrl } from "../lib/strapi";
import SectionHeading from "./ui/SectionHeading.astro";

interface Props {
  block: FeaturedServicesBlock;
  // When paired beside another block, drop the image + outer section/padding
  // and render heading + accordion only (fills a single column).
  paired?: boolean;
}

const { block, paired = false } = Astro.props;
const services = (block.services ?? []).filter((s) => s.slug);
const image = mediaUrl(block.image);

// Paired layout matches the live CCK site: navy filled accordion bars, gaps
// between rows, white text/chevron. Solo layout keeps the bordered-list style.
const listClass = paired
  ? "mt-8 space-y-3"
  : "mt-8 divide-y divide-border overflow-hidden rounded-card border border-border bg-surface";
const summaryClass = paired
  ? "flex cursor-pointer list-none items-center justify-between gap-4 rounded-xl bg-primary px-5 py-4 font-serif text-base font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
  : "flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-serif text-lg font-semibold text-primary transition-colors hover:bg-surface-muted";
const chevronClass = paired
  ? "size-5 shrink-0 text-primary-foreground transition-transform duration-200 group-open:rotate-180"
  : "size-5 shrink-0 text-accent transition-transform duration-200 group-open:rotate-180";
const panelClass = paired ? "px-5 pb-5 pt-4" : "px-5 pb-5";
---

{/* Inner content: heading + accordion. Reused bare (paired) or in its own grid. */}
{
  (() => {
    const Accordion = (
      <div>
        {paired ? (
          <h2 class="text-center font-serif text-3xl font-bold tracking-tight text-primary sm:text-4xl">
            {block.heading ?? "Our Services"}
          </h2>
        ) : (
          <SectionHeading
            eyebrow={block.eyebrow ?? undefined}
            title={block.heading ?? "Our Services"}
          />
        )}

        <div class={listClass}>
          {services.map((service) => (
            <details class="group">
              <summary class={summaryClass}>
                <span>{service.title}</span>
                <svg
                  class={chevronClass}
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>
              <div class={panelClass}>
                {service.description && (
                  <p class="mb-4 text-sm leading-relaxed text-muted-foreground">
                    {service.description}
                  </p>
                )}
                <a
                  href={`/services/${service.slug}`}
                  class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
                >
                  Read More
                  <span aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </details>
          ))}
        </div>
      </div>
    );

    if (paired) return Accordion;

    return (
      <section>
        <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
          <div class="grid grid-cols-1 items-center gap-8 md:grid-cols-2">
            <div class="overflow-hidden rounded-card bg-surface">
              {image && (
                <img
                  src={image}
                  alt={block.image?.alternativeText ?? ""}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              )}
            </div>
            {Accordion}
          </div>
        </div>
      </section>
    );
  })()
}
