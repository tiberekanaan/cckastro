---
import type { CommissionerProfilesBlock } from "../../types/strapi";
import { mediaUrl } from "../../lib/strapi";

interface Props {
  block: CommissionerProfilesBlock;
}

const { block } = Astro.props;
const commissioners = block.commissioners ?? [];
---

<section class="bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    {
      (block.eyebrow || block.heading) && (
        <header class="mb-10 text-center">
          {block.eyebrow && (
            <span class="text-xs font-semibold uppercase tracking-wide text-accent">
              {block.eyebrow}
            </span>
          )}
          {block.heading && (
            <h2 class="mt-2 font-serif text-3xl font-bold text-primary sm:text-4xl">
              {block.heading}
            </h2>
          )}
        </header>
      )
    }

    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        commissioners.map((c) => {
          const photo = mediaUrl(c.image) ?? "/default-avatar.svg";
          return (
            <li>
              <a
                href={`/commissioners/${c.slug}`}
                class="group flex h-full flex-col items-center rounded-card border border-border bg-surface p-8 text-center transition-shadow hover:shadow-lg"
              >
                <img
                  src={photo}
                  alt={c.image?.alternativeText ?? c.name ?? ""}
                  class="size-32 rounded-full object-cover"
                />
                <p class="mt-5 font-serif text-xl font-semibold text-primary group-hover:text-accent">
                  {c.name}
                </p>
                {c.role && (
                  <p class="mt-1 text-sm text-muted-foreground">{c.role}</p>
                )}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
