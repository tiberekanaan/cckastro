---
import type { CommissionerProfilesBlock } from "../../types/strapi";
import { mediaUrl } from "../../lib/strapi";

interface Props {
  block: CommissionerProfilesBlock;
}

const { block } = Astro.props;
const commissioners = block.commissioners ?? [];
---

<section>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    {
      (block.eyebrow || block.heading) && (
        <header class="mb-10 flex flex-col items-center text-center">
          {block.eyebrow && (
            <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-accent">
              <span class="size-1.5 rounded-full bg-accent" aria-hidden="true" />
              {block.eyebrow}
            </span>
          )}
          {block.heading && (
            <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-primary sm:text-4xl">
              {block.heading}
            </h2>
          )}
        </header>
      )
    }

    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        commissioners.map((c) => {
          const photo = mediaUrl(c.image) ?? "/default-avatar.svg";
          return (
            <li>
              <a
                href={`/commissioners/${c.slug}`}
                class="group flex h-full flex-col items-center rounded-card bg-surface p-8 text-center shadow-[var(--shadow-soft)] ring-1 ring-border/60 transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]"
              >
                <img
                  src={photo}
                  alt={c.image?.alternativeText ?? c.name ?? ""}
                  class="size-32 rounded-full object-cover ring-4 ring-primary/10"
                />
                <p class="mt-5 text-xl font-bold text-primary group-hover:text-accent">
                  {c.name}
                </p>
                {c.role && (
                  <p class="mt-1 text-sm text-muted-foreground">{c.role}</p>
                )}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
