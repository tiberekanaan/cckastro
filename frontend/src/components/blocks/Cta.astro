---
import type { CtaBlock } from "../../types/strapi";
import { mediaUrl } from "../../lib/strapi";

interface Props {
  block: CtaBlock;
}

const { block } = Astro.props;
const isDanger = block.variant === "danger";
const img = mediaUrl(block.image);
---

{
  isDanger ? (
    <section>
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
        <div class="grid items-center gap-8 rounded-[var(--radius-panel)] bg-surface p-8 shadow-soft ring-1 ring-border/60 sm:p-12 lg:grid-cols-[1fr_auto]">
          <div class="max-w-xl">
            <h2 class="font-serif text-2xl font-bold tracking-tight text-primary sm:text-3xl">
              {block.title}
            </h2>
            {block.body && <p class="mt-3 text-muted-foreground">{block.body}</p>}
            {block.ctaLabel && block.ctaHref && (
              <a
                href={block.ctaHref}
                class="mt-6 inline-flex items-center gap-2 rounded-full bg-danger px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
              >
                {block.ctaLabel} &rarr;
              </a>
            )}
          </div>
          {img && (
            <img
              src={img}
              alt={block.image?.alternativeText ?? ""}
              class="h-44 w-44 justify-self-center object-contain"
            />
          )}
        </div>
      </div>
    </section>
  ) : (
    <section class="py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="relative isolate overflow-hidden rounded-[var(--radius-panel)] bg-white px-6 py-16 text-center shadow-xl ring-1 ring-border/60 sm:px-12 sm:py-20">
          <span class="mx-auto mb-6 block h-1.5 w-16 rounded-full bg-primary/25" />

          <h2 class="font-serif text-3xl font-bold tracking-tight text-primary sm:text-4xl">
            {block.title}
          </h2>
          {block.body && (
            <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-foreground/70">
              {block.body}
            </p>
          )}
          {block.ctaLabel && block.ctaHref && (
            <div class="mt-8 flex justify-center">
              <a
                href={block.ctaHref}
                class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-[var(--shadow-soft)] transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-[var(--shadow-lift)] focus-visible:outline-2 focus-visible:outline-offset-2"
              >
                {block.ctaLabel}
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
