---
import type { MarketInsightBlock } from "../../types/strapi";

interface Props {
  block: MarketInsightBlock;
}

const { block } = Astro.props;
---

<section class="bg-surface-muted">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div
      class="mx-auto max-w-sm rounded-card border border-border bg-surface p-8 text-center"
    >
      <p class="font-serif text-4xl font-bold text-primary">{block.value}</p>
      <p class="mt-2 text-sm font-medium uppercase tracking-wide text-muted-foreground">
        {block.label}
      </p>
    </div>
  </div>
</section>
