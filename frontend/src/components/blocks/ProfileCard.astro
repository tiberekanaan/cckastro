---
import type { ProfileCardBlock } from "../../types/strapi";
import { mediaUrl } from "../../lib/strapi";

interface Props {
  block: ProfileCardBlock;
}

const { block } = Astro.props;
const photo = mediaUrl(block.photo);
---

<section class="bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <figure
      class="mx-auto flex max-w-sm flex-col items-center rounded-card border border-border bg-surface p-8 text-center"
    >
      {
        photo ? (
          <img
            src={photo}
            alt={block.photo?.alternativeText ?? block.name ?? ""}
            class="size-28 rounded-full object-cover"
          />
        ) : (
          <div
            class="grid size-28 place-items-center rounded-full bg-surface-muted font-serif text-3xl text-primary"
            aria-hidden="true"
          >
            {block.name?.charAt(0) ?? "?"}
          </div>
        )
      }
      <figcaption class="mt-4">
        <p class="font-serif text-xl font-semibold text-primary">{block.name}</p>
        {block.title && (
          <p class="mt-1 text-sm text-muted-foreground">{block.title}</p>
        )}
      </figcaption>
    </figure>
  </div>
</section>
