---
import type { ProfileCardBlock } from "../../types/strapi";
import { mediaUrl } from "../../lib/strapi";

interface Props {
  block: ProfileCardBlock;
}

const { block } = Astro.props;
const photo = mediaUrl(block.photo);
---

<section>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <figure
      class="mx-auto flex max-w-sm flex-col items-center rounded-card bg-surface p-8 text-center shadow-[var(--shadow-soft)] ring-1 ring-border/60"
    >
      {
        photo ? (
          <img
            src={photo}
            alt={block.photo?.alternativeText ?? block.name ?? ""}
            class="size-28 rounded-full object-cover ring-4 ring-primary/10"
          />
        ) : (
          <div
            class="grid size-28 place-items-center rounded-full bg-primary/10 text-3xl font-bold text-primary"
            aria-hidden="true"
          >
            {block.name?.charAt(0) ?? "?"}
          </div>
        )
      }
      <figcaption class="mt-4">
        <p class="text-xl font-bold text-primary">{block.name}</p>
        {block.title && (
          <p class="mt-1 text-sm text-muted-foreground">{block.title}</p>
        )}
      </figcaption>
    </figure>
  </div>
</section>
