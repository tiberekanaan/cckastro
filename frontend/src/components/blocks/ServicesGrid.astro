---
import type { ServicesGridBlock } from "../../types/strapi";
import { Icon } from "astro-icon/components";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  block: ServicesGridBlock;
  // When paired beside the market block, render as navy icon accordion bars
  // (matches the live CCK site) instead of the standalone card grid.
  paired?: boolean;
}

const { block, paired = false } = Astro.props;
const services = block.services ?? [];

// Fallback when a service has no icon set in the CMS.
const FALLBACK_ICON = "lucide:network";

// Normalize CMS values to a full Iconify name; default to the lucide set
// when the editor omits a prefix (e.g. "wifi" -> "lucide:wifi").
const iconFor = (icon?: string | null): string =>
  !icon ? FALLBACK_ICON : icon.includes(":") ? icon : `lucide:${icon}`;
---

{
  paired ? (
    <div>
      <h2 class="text-center font-serif text-3xl font-bold tracking-tight text-primary sm:text-4xl">
        {block.heading ?? "Our Services"}
      </h2>
      <div class="mt-8 space-y-3">
        {services.map((service) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center gap-3 rounded-xl bg-primary px-5 py-4 font-serif text-base font-semibold text-primary-foreground transition-colors hover:bg-primary/90">
              <Icon name={iconFor(service.icon)} class="size-5 shrink-0" />
              <span class="flex-1">{service.title}</span>
              <svg
                class="size-5 shrink-0 transition-transform duration-200 group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-4">
              {service.summary && (
                <p class="mb-4 text-sm leading-relaxed text-muted-foreground">
                  {service.summary}
                </p>
              )}
              <a
                href={service.href ?? "#"}
                class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
              >
                Learn more
                <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </details>
        ))}
      </div>
    </div>
  ) : (
    <section>
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
        <SectionHeading
          eyebrow={block.eyebrow ?? undefined}
          title={block.heading ?? "Our Services"}
        />
        <ul class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <li>
            <a
              href={service.href ?? "#"}
              class="group flex h-full flex-col gap-4 rounded-card bg-surface p-6 shadow-[var(--shadow-soft)] ring-1 ring-border/60 transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]"
            >
              <span
                class="grid size-12 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground"
                aria-hidden="true"
              >
                <Icon name={iconFor(service.icon)} class="size-6" />
              </span>
              <span class="flex-1">
                <span class="block text-lg font-bold leading-tight text-primary">
                  {service.title}
                </span>
                {service.summary && (
                  <span class="mt-2 block text-sm leading-relaxed text-muted-foreground">
                    {service.summary}
                  </span>
                )}
              </span>
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
                Learn more
                <svg
                  class="size-4 transition-transform group-hover:translate-x-1"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 6 6 6-6 6" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
        </ul>
      </div>
    </section>
  )
}
