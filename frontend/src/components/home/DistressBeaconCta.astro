---
import { site } from "../../data/site";

const { distress } = site;
---

<section class="bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div
      class="grid items-center gap-8 rounded-card border border-border bg-surface-muted p-8 sm:p-12 lg:grid-cols-[1fr_auto]"
    >
      <div class="max-w-xl">
        <h2 class="font-serif text-2xl font-bold text-primary sm:text-3xl">
          Do you own a <span class="text-danger">distress beacon</span>?
        </h2>
        <p class="mt-3 text-muted-foreground">{distress.body}</p>
        <a
          href={distress.cta.href}
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-danger px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          {distress.cta.label} &rarr;
        </a>
      </div>

      <div class="justify-self-center" aria-hidden="true">
        <svg
          class="h-44 w-44"
          viewBox="0 0 160 160"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <g
            stroke="var(--color-danger)"
            stroke-width="3"
            opacity="0.55"
          >
            <path d="M118 38a40 40 0 0 1 0 56"></path>
            <path d="M130 26a58 58 0 0 1 0 80"></path>
          </g>
          <rect x="52" y="60" width="44" height="74" rx="10" fill="var(--color-danger)"></rect>
          <rect x="60" y="44" width="28" height="20" rx="5" fill="#3a3f4a"></rect>
          <path d="M74 44V30" stroke="#3a3f4a" stroke-width="4"></path>
          <circle cx="74" cy="26" r="5" fill="#3a3f4a"></circle>
          <rect x="62" y="76" width="24" height="16" rx="3" fill="#ffffff" opacity="0.9"></rect>
          <circle cx="74" cy="112" r="9" fill="#ffd23f"></circle>
        </svg>
      </div>
    </div>
  </div>
</section>
