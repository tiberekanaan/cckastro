---
import { site } from "../../data/site";
import Button from "../ui/Button.astro";

const { help } = site;
---

<section class="bg-surface pb-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div
      class="rounded-card bg-primary px-6 py-14 text-center text-primary-foreground sm:px-12"
    >
      <h2 class="font-serif text-3xl font-bold sm:text-4xl">{help.title}</h2>
      <p class="mx-auto mt-3 max-w-xl text-primary-foreground/75">
        {help.body}
      </p>
      <div class="mt-7 flex justify-center">
        <Button href={help.cta.href} variant="primary">{help.cta.label}</Button>
      </div>
    </div>
  </div>
</section>
