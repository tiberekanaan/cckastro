---
import { site } from "../../data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-primary text-primary-foreground">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="max-w-xs">
        <span class="font-serif text-xl font-bold">{site.shortName}</span>
        <p class="mt-3 text-sm text-primary-foreground/70">{site.name}</p>
        <address class="mt-4 not-italic text-sm text-primary-foreground/70">
          {site.address}<br />
          <a href={`mailto:${site.email}`} class="hover:underline"
            >{site.email}</a
          ><br />
          <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:underline"
            >{site.phone}</a
          >
        </address>
      </div>

      {
        site.footer.columns.map((col) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-primary-foreground/90">
              {col.heading}
            </h3>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-primary-foreground/15 pt-6 text-xs text-primary-foreground/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p class="flex gap-4">
        <a href="/privacy" class="hover:text-primary-foreground">Privacy</a>
        <a href="/terms" class="hover:text-primary-foreground">Terms</a>
      </p>
    </div>
  </div>
</footer>
