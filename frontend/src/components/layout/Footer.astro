---
import { site } from "../../data/site";
import { getNavigation } from "../../lib/strapi";
import type { GlobalSettings } from "../../types/strapi";

interface Props {
  settings: GlobalSettings;
}

const { settings } = Astro.props;
const logoSrc = settings.logoUrl ?? "/cck-logo.png";

const year = new Date().getFullYear();

// Editable footer columns from Strapi (falls back to site.ts).
const { footerColumns } = await getNavigation();
---

<footer class="border-t border-border bg-primary text-primary-foreground">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="max-w-xs">
        <span class="flex items-center gap-2.5">
          <img
            src={logoSrc}
            alt=""
            width="36"
            height="36"
            class="h-9 w-9 rounded-full bg-primary-foreground object-contain p-1"
          />
          <span class="text-xl font-extrabold tracking-tight">{site.shortName}</span>
        </span>
        <p class="mt-3 text-sm text-primary-foreground/70">{settings.siteName}</p>
        <address class="mt-4 not-italic text-sm text-primary-foreground/70">
          <span class="whitespace-pre-line">{settings.contactAddress}</span><br />
          <a href={`mailto:${settings.contactEmail}`} class="hover:underline"
            >{settings.contactEmail}</a
          ><br />
          <a
            href={`tel:${settings.contactPhone.replace(/\s/g, "")}`}
            class="hover:underline">{settings.contactPhone}</a
          >
        </address>
      </div>

      {
        footerColumns.map((col) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-primary-foreground/90">
              {col.heading}
            </h3>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-primary-foreground/15 pt-6 text-xs text-primary-foreground/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p class="flex gap-4">
        <a href="/privacy" class="hover:text-primary-foreground">Privacy</a>
        <a href="/terms" class="hover:text-primary-foreground">Terms</a>
      </p>
    </div>
  </div>
</footer>
