---
import { site } from "../../data/site";
import { getNavigation } from "../../lib/strapi";
import type { GlobalSettings } from "../../types/strapi";
import Button from "../ui/Button.astro";

interface Props {
  /* Transparent overlay mode: header floats over a full-bleed hero. */
  overlay?: boolean;
  settings: GlobalSettings;
}

const { overlay = false, settings } = Astro.props;
const logoSrc = settings.logoUrl ?? "/cck-logo.png";

// Editable header links from Strapi (falls back to site.ts).
const { headerLinks } = await getNavigation();
---

<header
  class:list={[
    "z-40",
    overlay
      ? "absolute inset-x-0 top-0"
      : "sticky top-0 border-b border-border bg-surface/90 backdrop-blur",
  ]}
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a href="/" class="flex items-center gap-3" aria-label={settings.siteName}>
      <img
        src={logoSrc}
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 shrink-0 object-contain"
      />
      <span class="leading-tight">
        <span
          class:list={[
            "block text-lg font-extrabold tracking-tight",
            overlay ? "text-white" : "text-primary",
          ]}>{site.shortName}</span
        >
        <span
          class:list={[
            "block text-[11px]",
            overlay ? "text-white/70" : "text-muted-foreground",
          ]}>Comms Commission of Kiribati</span
        >
      </span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        headerLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              overlay
                ? "text-white/85 hover:text-white"
                : "text-foreground/80 hover:text-accent",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:block">
      <Button href="/contact" variant="primary" class="px-5 py-2.5">
        Contact
      </Button>
    </div>

    <!-- Mobile menu: CSS-only disclosure, Zero-JS -->
    <details class="group relative lg:hidden">
      <summary
        class:list={[
          "flex cursor-pointer items-center rounded-md border p-2 [&::-webkit-details-marker]:hidden",
          overlay ? "border-white/30 text-white" : "border-border text-primary",
        ]}
        aria-label="Toggle menu"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path class="group-open:hidden" d="M4 7h16M4 12h16M4 17h16"></path>
          <path class="hidden group-open:block" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </summary>
      <div
        class="absolute right-0 mt-2 w-60 rounded-card border border-border bg-surface p-3 shadow-lg"
      >
        <nav class="flex flex-col" aria-label="Mobile">
          {
            headerLinks.map((link) => (
              <a
                href={link.href}
                class="rounded-md px-3 py-2 text-sm font-medium text-foreground/80 hover:bg-surface-muted hover:text-accent"
              >
                {link.label}
              </a>
            ))
          }
          <Button href="/contact" variant="primary" class="mt-2 w-full"
            >Contact</Button
          >
        </nav>
      </div>
    </details>
  </div>
</header>
