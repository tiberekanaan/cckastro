---
import { site } from "../../data/site";
import Button from "../ui/Button.astro";
---

<header
  class="sticky top-0 z-40 border-b border-border bg-surface/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a href="/" class="flex items-center gap-3" aria-label={site.name}>
      <svg
        class="h-10 w-10 shrink-0"
        viewBox="0 0 40 40"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="20" cy="20" r="19" fill="var(--color-primary)"></circle>
        <path
          d="M14 25a9 9 0 0 1 0-10"
          stroke="var(--color-secondary)"
          stroke-width="2.4"
          stroke-linecap="round"></path>
        <path
          d="M26 15a9 9 0 0 1 0 10"
          stroke="var(--color-primary-foreground)"
          stroke-width="2.4"
          stroke-linecap="round"></path>
        <circle cx="20" cy="20" r="3" fill="var(--color-secondary)"></circle>
      </svg>
      <span class="leading-tight">
        <span class="block font-serif text-lg font-bold text-primary"
          >{site.shortName}</span
        >
        <span class="block text-[11px] text-muted-foreground"
          >Comms Commission of Kiribati</span
        >
      </span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        site.nav.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-foreground/80 transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:block">
      <Button href="/contact" variant="primary" class="px-5 py-2.5">
        Contact
      </Button>
    </div>

    <!-- Mobile menu: CSS-only disclosure, Zero-JS -->
    <details class="group relative lg:hidden">
      <summary
        class="flex cursor-pointer items-center rounded-md border border-border p-2 text-primary [&::-webkit-details-marker]:hidden"
        aria-label="Toggle menu"
      >
        <svg
          class="h-6 w-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path class="group-open:hidden" d="M4 7h16M4 12h16M4 17h16"></path>
          <path class="hidden group-open:block" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </summary>
      <div
        class="absolute right-0 mt-2 w-60 rounded-card border border-border bg-surface p-3 shadow-lg"
      >
        <nav class="flex flex-col" aria-label="Mobile">
          {
            site.nav.map((link) => (
              <a
                href={link.href}
                class="rounded-md px-3 py-2 text-sm font-medium text-foreground/80 hover:bg-surface-muted hover:text-accent"
              >
                {link.label}
              </a>
            ))
          }
          <Button href="/contact" variant="primary" class="mt-2 w-full"
            >Contact</Button
          >
        </nav>
      </div>
    </details>
  </div>
</header>
