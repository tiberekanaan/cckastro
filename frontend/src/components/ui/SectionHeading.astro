---
interface Props {
  eyebrow?: string;
  title: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, align = "left", class: className } = Astro.props;
---

<div
  class:list={[
    "flex flex-col gap-2",
    align === "center" && "items-center text-center",
    className,
  ]}
>
  {
    eyebrow && (
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
        {eyebrow}
      </span>
    )
  }
  <h2 class="font-serif text-3xl font-semibold text-primary sm:text-4xl">
    {title}
  </h2>
</div>
