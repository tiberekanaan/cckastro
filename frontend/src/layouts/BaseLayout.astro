---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/inter";
import "@fontsource/lora/500.css";
import "@fontsource/lora/600.css";
import "@fontsource/lora/700.css";
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /* Float a transparent header over a full-bleed hero (home page). */
  heroOverlay?: boolean;
}

const {
  title,
  description = "The Communications Commission of Kiribati regulates the national telecommunication market.",
  heroOverlay = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-surface-muted text-foreground">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>
    <Header overlay={heroOverlay} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
