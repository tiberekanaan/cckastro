---
export const prerender = false;

import { getCollection } from "astro:content";
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;

const jobs = await getCollection("jobs");
const job = jobs.find((entry) => entry.data.slug === slug);

if (!job) {
  return Astro.redirect("/career");
}

const { title, openingDate, closingDate, description, applicationInstructions } =
  job.data;

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
const fmtDate = (d: Date): string => dateFmt.format(d);

// Strapi `richtext` returns Markdown; render to HTML (CMS-authored, trusted).
const descriptionHtml = await marked.parse(description);
const instructionsHtml = await marked.parse(applicationInstructions);

const prose =
  "[&_a]:text-accent [&_a]:underline [&_h2]:mt-8 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-primary [&_h3]:mt-6 [&_h3]:font-semibold [&_h3]:text-lg [&_h3]:text-primary [&_li]:mt-1 [&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mt-4 [&_strong]:text-primary [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6";
---

<BaseLayout title={`${title} — Careers`} description={`Job opening: ${title}.`}>
  <section class="bg-surface-muted">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
      <a
        href="/career"
        class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
      >
        <span>&larr;</span> Back to Careers
      </a>

      <header class="mt-6">
        <h1
          class="font-serif text-4xl font-bold leading-tight text-primary sm:text-5xl"
        >
          {title}
        </h1>

        <dl
          class="mt-6 flex flex-wrap gap-x-10 gap-y-2 text-sm text-muted-foreground"
        >
          <div>
            <dt class="font-semibold uppercase tracking-wide text-slate-500">
              Opening date
            </dt>
            <dd class="mt-0.5 text-base text-primary">{fmtDate(openingDate)}</dd>
          </div>
          <div>
            <dt class="font-semibold uppercase tracking-wide text-slate-500">
              Closing date
            </dt>
            <dd class="mt-0.5 text-base text-primary">{fmtDate(closingDate)}</dd>
          </div>
        </dl>
      </header>

      <article class={`mt-8 text-base leading-relaxed text-muted-foreground ${prose}`} set:html={descriptionHtml} />

      <div
        class="mt-8 rounded-r-lg border-l-4 border-teal-600 bg-teal-50 p-6"
      >
        <h2 class="font-serif text-2xl font-bold text-teal-900">How to Apply</h2>
        <div
          class={`mt-3 text-base leading-relaxed text-teal-900/80 ${prose}`}
          set:html={instructionsHtml}
        />
      </div>
    </div>
  </section>
</BaseLayout>
