---
export const prerender = false;

import { marked } from "marked";
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { STRAPI_URL } from "../../lib/strapi";
import type { Career, StrapiCollectionResponse } from "../../types/strapi";

// Open roles only: deadline today or later (compare on date, not time).
const today = new Date().toISOString().slice(0, 10);

const query = new URLSearchParams();
query.set("filters[deadline][$gte]", today);
query.set("sort", "deadline:asc");

let careers: Career[] = [];
let loadError = false;

try {
  const res = await fetch(`${STRAPI_URL}/api/careers?${query}`);
  if (!res.ok) throw new Error(`Strapi /api/careers → ${res.status}`);
  const json: StrapiCollectionResponse<Career> = await res.json();
  careers = json.data ?? [];
} catch (err) {
  console.error("[careers] Strapi fetch failed:", err);
  loadError = true;
}

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const cards = await Promise.all(
  careers.map(async (job) => ({
    ...job,
    bodyHtml: job.description ? await marked.parse(job.description) : "",
    deadlineLabel: dateFmt.format(new Date(job.deadline)),
  })),
);
---

<BaseLayout
  title="Careers — Join the Commission | CCK"
  description="Current job openings at the Communications Commission of Kiribati. Explore vacancies and apply before the deadline."
>
  <section class="bg-surface">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:py-16">
      <header class="max-w-2xl">
        <h1 class="font-serif text-4xl font-bold leading-tight text-primary">
          Careers
        </h1>
        <p class="mt-3 text-muted-foreground">
          Join the team shaping Kiribati's communications future. Browse our
          current openings below.
        </p>
      </header>

      {
        loadError && (
          <p class="mt-10 rounded-card border border-danger/30 bg-danger/5 p-4 text-sm text-danger">
            We couldn't reach the content service. Please try again shortly.
          </p>
        )
      }

      {
        !loadError && cards.length === 0 && (
          <div class="mt-12 flex flex-col items-center justify-center rounded-card border border-dashed border-border bg-surface-muted px-6 py-16 text-center">
            <Icon
              name="lucide:briefcase"
              class="h-10 w-10 text-muted-foreground/60"
            />
            <p class="mt-4 text-lg font-semibold text-foreground">
              No job openings
            </p>
            <p class="mt-1 text-sm text-muted-foreground">
              There are no vacancies at the moment. Please check back later.
            </p>
          </div>
        )
      }

      {
        !loadError && cards.length > 0 && (
          <ul class="mt-10 space-y-6">
            {cards.map((job) => (
              <li class="rounded-card border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md sm:p-8">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <h2 class="font-serif text-xl font-bold leading-snug text-primary">
                    {job.title}
                  </h2>
                  <span class="inline-flex w-fit shrink-0 items-center gap-1.5 rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
                    <Icon name="lucide:calendar-clock" class="h-3.5 w-3.5" />
                    Apply by {job.deadlineLabel}
                  </span>
                </div>
                <div
                  class="prose-cck mt-4 text-foreground/80 [&_a]:text-accent [&_a:hover]:underline [&_li]:my-1 [&_ol]:my-2 [&_ol]:list-decimal [&_ol]:pl-5 [&_p]:my-2 [&_strong]:font-semibold [&_ul]:my-2 [&_ul]:list-disc [&_ul]:pl-5"
                  set:html={job.bodyHtml}
                />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>
