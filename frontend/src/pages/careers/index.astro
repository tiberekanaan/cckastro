---
export const prerender = false;

import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { STRAPI_URL } from "../../lib/strapi";
import type {
  Career,
  CareersPage,
  StrapiCollectionResponse,
} from "../../types/strapi";

// Open roles only: deadline today or later (compare on date, not time).
const today = new Date().toISOString().slice(0, 10);

let page: CareersPage | null = null;
let careers: Career[] = [];
let loadError = false;

// Editable page copy — a missing/unpublished single type (404) must not blank
// out the jobs table, so it's fetched independently from the listings.
try {
  const res = await fetch(`${STRAPI_URL}/api/careers-page`);
  if (res.ok) {
    const json: { data: CareersPage | null } = await res.json();
    page = json.data ?? null;
  } else if (res.status !== 404) {
    throw new Error(`Strapi /api/careers-page → ${res.status}`);
  }
} catch (err) {
  console.error("[careers] page-copy fetch failed:", err);
}

try {
  const query = new URLSearchParams();
  query.set("filters[deadline][$gte]", today);
  query.set("sort", "deadline:asc");
  const res = await fetch(`${STRAPI_URL}/api/careers?${query}`);
  if (!res.ok) throw new Error(`Strapi /api/careers → ${res.status}`);
  const json: StrapiCollectionResponse<Career> = await res.json();
  careers = json.data ?? [];
} catch (err) {
  console.error("[careers] listings fetch failed:", err);
  loadError = true;
}

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const fmtDate = (d?: string | null): string =>
  d ? dateFmt.format(new Date(d)) : "";

const heading = page?.title ?? "Careers";
// Strapi `richtext` returns Markdown; render to HTML (CMS-authored, trusted).
const introHtml = page?.intro
  ? await marked.parse(page.intro)
  : "<p>Join the team shaping Kiribati's communications future. Browse our current openings below.</p>";
---

<BaseLayout
  title={heading}
  description="Current job openings at the Communications Commission of Kiribati. Explore vacancies and apply before the deadline."
>
  <section class="bg-surface-muted">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
      <header class="max-w-3xl">
        <h1
          class="font-serif text-4xl font-bold leading-tight text-primary sm:text-5xl"
        >
          {heading}
        </h1>
        <div
          class="prose-cck mt-3 text-lg text-muted-foreground [&_a]:text-accent [&_a:hover]:underline [&_p]:mt-3 first:[&_p]:mt-0"
          set:html={introHtml}
        />
      </header>

      {
        careers.length > 0 ? (
          <div class="mt-10 overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-black/5">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50">
                  <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wide text-slate-500">
                    Position
                  </th>
                  <th class="whitespace-nowrap px-6 py-4 text-sm font-semibold uppercase tracking-wide text-slate-500">
                    Application Deadline
                  </th>
                  <th class="px-6 py-4">
                    <span class="sr-only">View</span>
                  </th>
                </tr>
              </thead>
              <tbody>
                {careers.map((job) => (
                  <tr class="group border-b border-slate-100 transition-colors last:border-0 hover:bg-slate-50/60">
                    <td class="px-6 py-4">
                      <a
                        href={`/careers/${job.documentId}`}
                        class="font-serif text-lg font-bold text-slate-900 transition-colors hover:text-teal-600 group-hover:text-teal-600"
                      >
                        {job.title}
                      </a>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4">
                      <span class="inline-flex items-center gap-1.5 rounded-full bg-lime-50 px-3 py-1 text-sm font-semibold text-lime-700">
                        {fmtDate(job.deadline)}
                      </span>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4 text-right">
                      <a
                        href={`/careers/${job.documentId}`}
                        class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
                      >
                        <span class="inline-flex items-center gap-1 transition-transform group-hover:translate-x-0.5">
                          View <span aria-hidden="true">&rarr;</span>
                        </span>
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="mt-10 rounded-2xl border border-slate-100 bg-white p-12 text-center">
            <h2 class="font-serif text-2xl font-bold text-primary">
              {loadError ? "Careers are unavailable" : "No job openings"}
            </h2>
            <p class="mt-3 text-muted-foreground">
              {loadError
                ? "We couldn't load current vacancies. Please try again shortly."
                : "There are no vacancies at the moment. Please check back later."}
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
