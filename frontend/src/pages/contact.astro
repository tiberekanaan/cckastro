---
export const prerender = false;

import { actions, isInputError } from "astro:actions";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getGlobalSettings } from "../lib/strapi";

// Editable contact info from Strapi (falls back to site.ts).
const settings = await getGlobalSettings();

const result = Astro.getActionResult(actions.contact.send);
const success = result && !result.error;
const inputError =
  result?.error && isInputError(result.error) ? result.error : null;
const fieldErrors = inputError?.fields ?? {};
// Non-validation failure (e.g. ActionError).
const formError = result?.error && !inputError ? result.error.message : null;

const inputClass =
  "mt-1 w-full rounded-lg border border-border bg-surface px-3 py-2 text-foreground focus-visible:border-accent focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-ring";
const labelClass = "block text-sm font-medium text-foreground";

// Exact pin: Communications Commission of Kiribati (maps.app.goo.gl/zHuZXWJR8LwMwGH16).
const mapSrc =
  "https://www.google.com/maps?q=1.3539794,172.9209376&z=17&output=embed";

const phoneHref = `tel:${settings.contactPhone.replace(/\s/g, "")}`;
const details = [
  {
    heading: "Email",
    value: settings.contactEmail,
    href: `mailto:${settings.contactEmail}`,
  },
  { heading: "Phone", value: settings.contactPhone, href: phoneHref },
  { heading: "Address", value: settings.contactAddress, href: null },
];
---

<BaseLayout
  title="Contact Us | CCK"
  description="Get in touch with the Communications Commission of Kiribati about licensing, consumer rights, or telecom services."
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <header class="mb-10 max-w-2xl">
      <h1 class="font-serif text-3xl font-bold text-primary sm:text-4xl">
        Contact Us
      </h1>
      <p class="mt-3 text-muted-foreground">
        Have a question about licensing, consumer rights, or telecom services in
        Kiribati? Send us a message and our team will get back to you.
      </p>
    </header>

    <div class="grid gap-10 lg:grid-cols-[1fr_1.4fr]">
      {/* --- Contact details --- */}
      <div class="space-y-6">
        <dl class="space-y-4">
          {
            details.map((item) => (
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
                  {item.heading}
                </dt>
                {item.href ? (
                  <dd>
                    <a
                      href={item.href}
                      class="text-foreground transition-colors hover:text-accent"
                    >
                      {item.value}
                    </a>
                  </dd>
                ) : (
                  <dd class="whitespace-pre-line text-foreground">{item.value}</dd>
                )}
              </div>
            ))
          }
        </dl>

        <div
          class="overflow-hidden rounded-card border border-border shadow-[var(--shadow-soft)]"
        >
          <iframe
            src={mapSrc}
            title="CCK location — Communications Commission of Kiribati, Tarawa, Kiribati"
            width="100%"
            height="300"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </div>
      </div>

      {/* --- Contact form --- */}
      <div>
        {
          success && (
            <div
              class="mb-6 rounded-card border border-accent bg-accent/10 p-4 text-sm font-medium text-foreground"
              role="status"
            >
              Thank you — your message has been received. We'll be in touch
              shortly.
            </div>
          )
        }

        {
          formError && (
            <div
              class="mb-6 rounded-card border border-red-500/50 bg-red-500/10 p-4 text-sm font-medium text-red-700"
              role="alert"
            >
              {formError}
            </div>
          )
        }

        <form
          method="POST"
          action={actions.contact.send}
          data-astro-reload
          class="grid gap-5 rounded-card border border-border bg-surface p-6 sm:p-8"
        >
          {/* Honeypot — hidden from users, bots fill it and get rejected. */}
          <input
            type="text"
            name="bot_catch_field"
            class="hidden absolute h-0 w-0 opacity-0"
            tabindex="-1"
            autocomplete="off"
          />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class={labelClass}>
              Name *
              <input class={inputClass} type="text" name="name" required />
              {
                fieldErrors.name && (
                  <span class="mt-1 block text-xs text-red-600">
                    {fieldErrors.name[0]}
                  </span>
                )
              }
            </label>
            <label class={labelClass}>
              Email *
              <input class={inputClass} type="email" name="email" required />
              {
                fieldErrors.email && (
                  <span class="mt-1 block text-xs text-red-600">
                    {fieldErrors.email[0]}
                  </span>
                )
              }
            </label>
          </div>

          <label class={labelClass}>
            Subject *
            <input class={inputClass} type="text" name="subject" required />
            {
              fieldErrors.subject && (
                <span class="mt-1 block text-xs text-red-600">
                  {fieldErrors.subject[0]}
                </span>
              )
            }
          </label>

          <label class={labelClass}>
            Message *
            <textarea class={inputClass} name="message" rows="6" required
            ></textarea>
            {
              fieldErrors.message && (
                <span class="mt-1 block text-xs text-red-600">
                  {fieldErrors.message[0]}
                </span>
              )
            }
          </label>

          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-accent-foreground transition-colors hover:bg-accent-hover"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
