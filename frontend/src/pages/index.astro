---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import ServicesAccordion from "../components/ServicesAccordion.astro";
import LatestNews from "../components/LatestNews.astro";
import { STRAPI_URL } from "../lib/strapi";
import type {
  StrapiCollectionResponse,
  StrapiPage,
  NewsItem,
} from "../types/strapi";

// Deep-populate each dynamic-zone block. `populate=*` does NOT descend into a
// dynamic zone's component fields in Strapi 5, so target each on a per-block
// basis. Hero explicitly populates its `image` media relation.
const blockPopulate: Record<string, string> = {
  "blocks.hero": "image",
  "blocks.services-grid": "*",
  "blocks.featured-services": "services",
  "blocks.cta": "*",
  "blocks.market-insight": "*",
  "blocks.profile-card": "*",
  "blocks.rich-text": "*",
  "blocks.faq": "*",
  "blocks.form": "*",
};
const populateQuery = Object.entries(blockPopulate)
  .map(([component, target]) => `populate[content][on][${component}][populate]=${target}`)
  .join("&");

// Target the home page deterministically by slug.
const HOME_SLUG = "home";

let page: StrapiPage | null = null;
let news: NewsItem[] = [];
let loadError = false;

try {
  const [pageRes, newsRes] = await Promise.all([
    fetch(
      `${STRAPI_URL}/api/pages?filters[slug][$eq]=${HOME_SLUG}&${populateQuery}`,
    ),
    fetch(
      `${STRAPI_URL}/api/news?sort=date:desc&pagination[limit]=3&populate=photo`,
    ),
  ]);

  if (!pageRes.ok) throw new Error(`Strapi /api/pages → ${pageRes.status}`);
  const pageJson: StrapiCollectionResponse<StrapiPage> = await pageRes.json();
  page = pageJson.data?.[0] ?? null;

  if (newsRes.ok) {
    const newsJson: StrapiCollectionResponse<NewsItem> = await newsRes.json();
    news = newsJson.data ?? [];
  }
} catch (err) {
  console.error("[index] Strapi fetch failed:", err);
  loadError = true;
}

const blocks = page?.content ?? [];
---

<BaseLayout
  title={page?.title ?? "CCK — Regulating Kiribati's telecommunication market"}
  description={page?.description ?? undefined}
>
  {
    loadError && (
      <section class="bg-surface">
        <div class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
          <h1 class="font-serif text-3xl font-bold text-primary">
            Content unavailable
          </h1>
          <p class="mt-3 text-muted-foreground">
            We couldn't reach the content service. Please try again shortly.
          </p>
        </div>
      </section>
    )
  }

  {
    !loadError && blocks.length === 0 && (
      <section class="bg-surface">
        <div class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
          <h1 class="font-serif text-3xl font-bold text-primary">
            No content yet
          </h1>
          <p class="mt-3 text-muted-foreground">
            Add blocks to a Page entry in Strapi to populate this site.
          </p>
        </div>
      </section>
    )
  }

  {
    blocks.map((block) =>
      block.__component === "blocks.featured-services" ? (
        <section class="bg-surface-muted">
          <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
            <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-2">
              <ServicesAccordion block={block} />
              {news.length > 0 && <LatestNews items={news} />}
            </div>
          </div>
        </section>
      ) : (
        <BlockRenderer block={block} />
      ),
    )
  }
</BaseLayout>
