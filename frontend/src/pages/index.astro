---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import ServicesGrid from "../components/blocks/ServicesGrid.astro";
import ServicesAccordion from "../components/ServicesAccordion.astro";
import MarketInsightsSection from "../components/blocks/MarketInsightsSection.astro";
import { STRAPI_URL } from "../lib/strapi";
import type {
  StrapiCollectionResponse,
  StrapiPage,
  NewsItem,
  PageBlock,
  ServicesGridBlock,
  FeaturedServicesBlock,
  MarketInsightsSectionBlock,
} from "../types/strapi";

// Deep-populate each dynamic-zone block. `populate=*` does NOT descend into a
// dynamic zone's component fields in Strapi 5, so target each on a per-block
// basis. Hero explicitly populates its `image` media relation.
// Each block lists its populate targets. Strapi 5 rejects comma-separated
// targets inside a dynamic-zone `[on]` populate, so multi-target blocks use the
// indexed-array form (`[populate][0]`, `[populate][1]`).
const blockPopulate: Record<string, string[]> = {
  "blocks.hero": ["image"],
  "blocks.services-grid": ["*"],
  "blocks.featured-services": ["services", "image"],
  "blocks.latest-news": ["image"],
  "blocks.cta": ["*"],
  "blocks.market-insight": ["*"],
  "blocks.profile-card": ["*"],
  "blocks.rich-text": ["*"],
  "blocks.faq": ["*"],
  "blocks.form": ["*"],
  "blocks.distress-beacon-cta": ["image"],
};
// Media nested inside a repeatable component (insights → icon) needs the
// object-form populate; the flat array form above can't express that depth.
// `=true` (not `=*`) for the image media relation — the wildcard makes Strapi
// descend into the file's `related` morph and 400s with "Invalid key related".
// `insights` is a repeatable component; populating it returns its string fields
// (label, value, iconName) — no nested media populate needed anymore.
const MARKET_INSIGHTS_POPULATE = [
  "populate[content][on][blocks.market-insights-section][populate][image]=true",
  "populate[content][on][blocks.market-insights-section][populate][insights]=true",
];

const populateQuery = [
  ...Object.entries(blockPopulate).flatMap(([component, targets]) =>
    targets.length === 1
      ? `populate[content][on][${component}][populate]=${targets[0]}`
      : targets.map(
          (t, i) => `populate[content][on][${component}][populate][${i}]=${t}`,
        ),
  ),
  ...MARKET_INSIGHTS_POPULATE,
].join("&");

// Target the home page deterministically by slug.
const HOME_SLUG = "home";

let page: StrapiPage | null = null;
let news: NewsItem[] = [];
let loadError = false;

try {
  const [pageRes, newsRes] = await Promise.all([
    fetch(
      `${STRAPI_URL}/api/pages?filters[slug][$eq]=${HOME_SLUG}&${populateQuery}`,
    ),
    fetch(
      `${STRAPI_URL}/api/news?sort=date:desc&pagination[limit]=3&populate=photo`,
    ),
  ]);

  if (!pageRes.ok) throw new Error(`Strapi /api/pages → ${pageRes.status}`);
  const pageJson: StrapiCollectionResponse<StrapiPage> = await pageRes.json();
  page = pageJson.data?.[0] ?? null;

  if (newsRes.ok) {
    const newsJson: StrapiCollectionResponse<NewsItem> = await newsRes.json();
    news = newsJson.data ?? [];
  }
} catch (err) {
  console.error("[index] Strapi fetch failed:", err);
  loadError = true;
}

const blocks = page?.content ?? [];

// Home hero is full-bleed: float a transparent header over it.
const heroOverlay = blocks[0]?.__component === "blocks.hero";

// Render items: most blocks render solo, but a services block (`services-grid`
// or `featured-services`) immediately followed by a `market-insights-section`
// is fused into one two-column row (services accordion left, market-at-a-glance
// right) — mirroring the live CCK site. Purely presentational; no CMS change.
type ServicesBlock = ServicesGridBlock | FeaturedServicesBlock;
const SERVICES_COMPONENTS = new Set([
  "blocks.services-grid",
  "blocks.featured-services",
]);
const isServicesBlock = (b: PageBlock): b is ServicesBlock =>
  SERVICES_COMPONENTS.has(b.__component);

type RenderItem =
  | { kind: "block"; block: PageBlock; card: boolean }
  | {
      kind: "pair";
      services: ServicesBlock;
      market: MarketInsightsSectionBlock;
      card: boolean;
    };

// Visual hierarchy: the page stays white; every other section after the Hero
// becomes a large muted rounded card, while the sections between them stay
// clean and full-width so the layout breathes. The Hero is never wrapped;
// alternation (index % 2 !== 0) starts on the items following it.
let bandIndex = 0;
const items: RenderItem[] = [];
for (let i = 0; i < blocks.length; i++) {
  const block = blocks[i];
  if (block.__component === "blocks.hero") {
    items.push({ kind: "block", block, card: false });
    continue;
  }
  const next = blocks[i + 1];
  if (
    isServicesBlock(block) &&
    next?.__component === "blocks.market-insights-section"
  ) {
    items.push({
      kind: "pair",
      services: block,
      market: next,
      card: bandIndex % 2 !== 0,
    });
    bandIndex++;
    i++; // consume the market block
    continue;
  }
  items.push({ kind: "block", block, card: bandIndex % 2 !== 0 });
  bandIndex++;
}
---

<BaseLayout
  title={page?.title ?? "CCK — Regulating Kiribati's telecommunication market"}
  description={page?.description ?? undefined}
  heroOverlay={heroOverlay}
>
  {
    loadError && (
      <section class="bg-surface">
        <div class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
          <h1 class="font-serif text-3xl font-bold text-primary">
            Content unavailable
          </h1>
          <p class="mt-3 text-muted-foreground">
            We couldn't reach the content service. Please try again shortly.
          </p>
        </div>
      </section>
    )
  }

  {
    !loadError && blocks.length === 0 && (
      <section class="bg-surface">
        <div class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
          <h1 class="font-serif text-3xl font-bold text-primary">
            No content yet
          </h1>
          <p class="mt-3 text-muted-foreground">
            Add blocks to a Page entry in Strapi to populate this site.
          </p>
        </div>
      </section>
    )
  }

  {
    items.map((item) => {
      /* Paired services + market-at-a-glance two-column row. */
      const inner =
        item.kind === "pair" ? (
          <div class="grid grid-cols-1 items-start gap-10 md:grid-cols-2">
            {item.services.__component === "blocks.services-grid" ? (
              <ServicesGrid block={item.services} paired />
            ) : (
              <ServicesAccordion block={item.services} paired />
            )}
            <MarketInsightsSection block={item.market} paired />
          </div>
        ) : (
          <BlockRenderer block={item.block} news={news} />
        );

      /* Pairs bring their own section padding; solo blocks already do. */
      const body =
        item.kind === "pair" ? (
          <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">{inner}</section>
        ) : (
          inner
        );

      /* Latest News always reads as a muted band; alternating sections do too. */
      const isLatestNews =
        item.kind === "block" &&
        item.block.__component === "blocks.latest-news";

      /* The closing CTA is a self-contained white card — never a muted band. */
      const isCta =
        item.kind === "block" && item.block.__component === "blocks.cta";

      return (item.card && !isCta) || isLatestNews ? (
        /* Full-bleed muted band — tinted background spans the viewport
           end-to-end; inner content stays centered by its own container. */
        <div class="bg-surface-muted">{body}</div>
      ) : (
        /* Non-alternating section: clean, full-width white. */
        body
      );
    })
  }
</BaseLayout>
