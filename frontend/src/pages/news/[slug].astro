---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import RichTextNode from "../../components/blocks/RichTextNode.astro";
import { STRAPI_URL, mediaUrl } from "../../lib/strapi";
import type { NewsItem, StrapiCollectionResponse } from "../../types/strapi";

const { slug } = Astro.params;

let article: NewsItem | null = null;
let loadError = false;

try {
  // Look up by clean slug first.
  const res = await fetch(
    `${STRAPI_URL}/api/news?filters[slug][$eq]=${slug}&populate=photo`,
  );
  if (!res.ok) throw new Error(`Strapi /api/news → ${res.status}`);
  const json: StrapiCollectionResponse<NewsItem> = await res.json();
  article = json.data?.[0] ?? null;

  // Legacy fallback: treat the param as a documentId for old links.
  if (!article) {
    const byId = await fetch(
      `${STRAPI_URL}/api/news/${slug}?populate=photo`,
    );
    if (byId.ok) {
      const j: { data: NewsItem | null } = await byId.json();
      const found = j.data ?? null;
      // Redirect to the clean URL when the entry now has a slug.
      if (found?.slug) return Astro.redirect(`/news/${found.slug}`, 301);
      article = found;
    }
  }
} catch (err) {
  console.error("[news/[slug]] Strapi fetch failed:", err);
  loadError = true;
}

if (!article && !loadError) Astro.response.status = 404;

// Other recent stories for the "More News" section (newest first, current excluded).
let moreNews: NewsItem[] = [];
if (article) {
  try {
    const query = new URLSearchParams();
    query.set("populate", "photo");
    query.set("sort", "date:desc");
    query.set("filters[documentId][$ne]", article.documentId ?? "");
    query.set("pagination[limit]", "3");
    const res = await fetch(`${STRAPI_URL}/api/news?${query}`);
    if (res.ok) {
      const json: { data: NewsItem[] } = await res.json();
      moreNews = json.data ?? [];
    }
  } catch (err) {
    console.error("[news/[slug]] more-news fetch failed:", err);
  }
}

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const fmtDate = (d?: string | null): string =>
  d ? dateFmt.format(new Date(d)) : "";

const photo = mediaUrl(article?.photo);
const body = article?.description ?? [];
---

<BaseLayout
  title={article?.title ?? "News not found"}
  description={undefined}
>
  <article class="bg-surface">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
      >
        <span aria-hidden="true">&larr;</span> Back
      </a>

      {
        article ? (
          <>
            <header class="mt-6">
              {article.date && (
                <span class="text-xs font-semibold uppercase tracking-wide text-accent">
                  News &middot; {fmtDate(article.date)}
                </span>
              )}
              <h1 class="mt-2 font-serif text-4xl font-bold leading-tight text-primary">
                {article.title}
              </h1>
            </header>

            {photo && (
              <img
                src={photo}
                alt={article.photo?.alternativeText ?? ""}
                class="mt-8 aspect-[16/9] w-full rounded-card object-cover"
              />
            )}

            <div class="mt-8">
              {body.map((node) => (
                <RichTextNode node={node} />
              ))}
            </div>
          </>
        ) : (
          <div class="py-16 text-center">
            <h1 class="font-serif text-3xl font-bold text-primary">
              Article not found
            </h1>
            <p class="mt-3 text-muted-foreground">
              This news item may have been moved or unpublished.
            </p>
          </div>
        )
      }
    </div>
  </article>

  {
    article && moreNews.length > 0 && (
      <section class="border-t border-border bg-surface-muted">
        <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:py-16">
          <h2 class="font-serif text-2xl font-bold text-primary sm:text-3xl">
            More News
          </h2>
          <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {moreNews.map((item) => (
              <a
                href={`/news/${item.slug ?? item.documentId}`}
                class="group flex h-full flex-col overflow-hidden rounded-2xl border-0 bg-white shadow-lg ring-1 ring-black/5 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
              >
                <div class="overflow-hidden">
                  <img
                    src={mediaUrl(item.photo) ?? "/news-placeholder.svg"}
                    alt={item.photo?.alternativeText ?? item.title ?? "News"}
                    loading="lazy"
                    class="aspect-[16/9] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                  />
                </div>
                <div class="flex grow flex-col p-6">
                  <span class="mb-2 text-sm font-semibold text-lime-600">
                    {fmtDate(item.date)}
                  </span>
                  <h3 class="line-clamp-2 font-serif text-xl font-bold text-slate-900 transition-colors group-hover:text-teal-600">
                    {item.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
