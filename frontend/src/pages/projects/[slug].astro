---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import RichTextNode from "../../components/blocks/RichTextNode.astro";
import { STRAPI_URL, mediaUrl } from "../../lib/strapi";
import type { Project, StrapiCollectionResponse } from "../../types/strapi";

const { slug } = Astro.params;

let project: Project | null = null;
let loadError = false;

try {
  // Look up by clean slug first.
  const res = await fetch(
    `${STRAPI_URL}/api/projects?filters[slug][$eq]=${slug}&populate=photos`,
  );
  if (!res.ok) throw new Error(`Strapi /api/projects → ${res.status}`);
  const json: StrapiCollectionResponse<Project> = await res.json();
  project = json.data?.[0] ?? null;

  // Legacy fallback: treat the param as a documentId for old links.
  if (!project) {
    const byId = await fetch(
      `${STRAPI_URL}/api/projects/${slug}?populate=photos`,
    );
    if (byId.ok) {
      const j: { data: Project | null } = await byId.json();
      const found = j.data ?? null;
      if (found?.slug) return Astro.redirect(`/projects/${found.slug}`, 301);
      project = found;
    }
  }
} catch (err) {
  console.error("[projects/[slug]] Strapi fetch failed:", err);
  loadError = true;
}

if (!project && !loadError) Astro.response.status = 404;

const photos = project?.photos ?? [];
const cover = mediaUrl(photos[0]);
const gallery = photos.slice(1);
const body = project?.description ?? [];
---

<BaseLayout title={project?.title ?? "Project not found"}>
  <article class="bg-surface">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16">
      <a
        href="/universal-access"
        class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover"
      >
        <span aria-hidden="true">&larr;</span> Back to UAF
      </a>

      {
        project ? (
          <>
            <header class="mt-6">
              <span class="text-xs font-semibold uppercase tracking-wide text-accent">
                Universal Access Fund
              </span>
              <h1 class="mt-2 font-serif text-4xl font-bold leading-tight text-primary">
                {project.title}
              </h1>
            </header>

            {cover && (
              <img
                src={cover}
                alt={photos[0]?.alternativeText ?? project.title ?? ""}
                class="mt-8 aspect-[16/9] w-full rounded-card object-cover"
              />
            )}

            <div class="mt-8">
              {body.map((node) => (
                <RichTextNode node={node} />
              ))}
            </div>

            {gallery.length > 0 && (
              <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3">
                {gallery.map((media) => (
                  <img
                    src={mediaUrl(media)}
                    alt={media.alternativeText ?? ""}
                    loading="lazy"
                    class="aspect-square w-full rounded-card object-cover"
                  />
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="py-16 text-center">
            <h1 class="font-serif text-3xl font-bold text-primary">
              Project not found
            </h1>
            <p class="mt-3 text-muted-foreground">
              This project may have been moved or unpublished.
            </p>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
