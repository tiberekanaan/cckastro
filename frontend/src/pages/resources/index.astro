---
export const prerender = false;

import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { STRAPI_URL } from "../../lib/strapi";
import type {
  OfficialDocument,
  StrapiCollectionResponse,
  StrapiPagination,
} from "../../types/strapi";

// --- URL params ---
const params = Astro.url.searchParams;
const q = params.get("q")?.trim() ?? "";
const type = params.get("type") ?? "";
const PAGE_SIZES = [8, 12, 24] as const;
const rawLimit = Number(params.get("limit"));
const limit = PAGE_SIZES.includes(rawLimit as (typeof PAGE_SIZES)[number])
  ? rawLimit
  : 8;
const page = Math.max(1, Number(params.get("page")) || 1);

// --- Build Strapi query (filters + pagination) ---
const query = new URLSearchParams();
query.set("populate", "file");
query.set("sort", "title:asc");
if (q) query.set("filters[title][$containsi]", q);
if (type === "Regulation" || type === "Rule") {
  query.set("filters[type][$eq]", type);
}
query.set("pagination[page]", String(page));
query.set("pagination[pageSize]", String(limit));

let docs: OfficialDocument[] = [];
let pagination: StrapiPagination | null = null;
let loadError = false;

try {
  const res = await fetch(`${STRAPI_URL}/api/official-documents?${query}`);
  if (!res.ok) throw new Error(`Strapi /api/official-documents → ${res.status}`);
  const json: StrapiCollectionResponse<OfficialDocument> = await res.json();
  docs = json.data ?? [];
  pagination = json.meta?.pagination ?? null;
} catch (err) {
  console.error("[resources] Strapi fetch failed:", err);
  loadError = true;
}

// Preserve search/filter/limit across pagination links.
const linkParams = (targetPage: number) => {
  const p = new URLSearchParams();
  if (q) p.set("q", q);
  if (type) p.set("type", type);
  p.set("limit", String(limit));
  p.set("page", String(targetPage));
  return `/resources?${p}`;
};

const hasPrev = page > 1;
const hasNext = pagination ? page < pagination.pageCount : false;

// Titles arrive inconsistently cased (some ALL CAPS, some Title Case);
// normalize to Title Case for a consistent grid.
const toTitleCase = (s: string) =>
  s
    .trim()
    .toLowerCase()
    .replace(/\b\w/g, (c) => c.toUpperCase());
---

<BaseLayout
  title="Resources — Rules & Regulations | CCK"
  description="Searchable library of official rules and regulations published by the Communications Commission of Kiribati."
>
  <section class="bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:py-16">
      <header class="max-w-2xl">
        <h1 class="font-serif text-4xl font-bold leading-tight text-primary">
          Rules &amp; Regulations
        </h1>
        <p class="mt-3 text-muted-foreground">
          Browse, search, and download official documents published by the
          Commission.
        </p>
      </header>

      <!-- Filter / search form (GET → SSR re-render, Zero-JS) -->
      <form
        method="GET"
        action="/resources"
        class="mt-8 grid grid-cols-1 gap-4 rounded-card border border-border bg-surface-muted p-4 sm:grid-cols-2 lg:grid-cols-[1fr_auto_auto_auto] lg:items-end"
      >
        <div class="flex flex-col gap-1">
          <label for="q" class="text-sm font-medium text-foreground">Search</label>
          <input
            id="q"
            type="search"
            name="q"
            value={q}
            placeholder="Search by title…"
            class="rounded-md border border-border bg-surface px-3 py-2 text-sm text-foreground outline-none focus:border-accent focus:ring-2 focus:ring-ring/30"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label for="type" class="text-sm font-medium text-foreground">Type</label>
          <select
            id="type"
            name="type"
            class="rounded-md border border-border bg-surface px-3 py-2 text-sm text-foreground outline-none focus:border-accent focus:ring-2 focus:ring-ring/30"
          >
            <option value="" selected={type === ""}>All</option>
            <option value="Regulation" selected={type === "Regulation"}>
              Regulation
            </option>
            <option value="Rule" selected={type === "Rule"}>Rule</option>
          </select>
        </div>

        <div class="flex flex-col gap-1">
          <label for="limit" class="text-sm font-medium text-foreground">
            Per page
          </label>
          <select
            id="limit"
            name="limit"
            class="rounded-md border border-border bg-surface px-3 py-2 text-sm text-foreground outline-none focus:border-accent focus:ring-2 focus:ring-ring/30"
          >
            {
              PAGE_SIZES.map((size) => (
                <option value={size} selected={limit === size}>
                  {size}
                </option>
              ))
            }
          </select>
        </div>

        <div class="flex items-stretch gap-2 sm:col-span-2 lg:col-span-1">
          <button
            type="submit"
            class="flex-1 rounded-md bg-accent px-4 py-2 text-sm font-semibold text-accent-foreground transition-colors hover:bg-accent-hover"
          >
            Apply
          </button>
          <a
            href="/resources"
            class="flex flex-1 items-center justify-center rounded-md border border-border bg-surface px-4 py-2 text-sm font-semibold text-foreground transition-colors hover:border-accent hover:text-accent"
          >
            Reset
          </a>
        </div>
      </form>

      {
        loadError && (
          <p class="mt-10 rounded-card border border-danger/30 bg-danger/5 p-4 text-sm text-danger">
            We couldn't reach the content service. Please try again shortly.
          </p>
        )
      }

      {
        !loadError && docs.length === 0 && (
          <p class="mt-10 text-muted-foreground">
            No documents match your search.
          </p>
        )
      }

      {
        !loadError && docs.length > 0 && (
          <ul class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
            {docs.map((doc) => {
              const isRegulation = doc.type === "Regulation";
              const fileUrl = doc.file?.url
                ? `${STRAPI_URL}${doc.file.url}`
                : null;
              return (
                <li class="flex flex-col overflow-hidden rounded-card border border-border bg-surface shadow-sm transition-shadow hover:shadow-md">
                  {/* Static document thumbnail — light card, type-differentiated graphic */}
                  <div class="flex h-44 items-center justify-center bg-surface-muted">
                    <img
                      src={
                        isRegulation
                          ? "/documents/regulation.svg"
                          : "/documents/rule.svg"
                      }
                      alt={`${doc.type} document`}
                      width="200"
                      height="200"
                      loading="lazy"
                      class="h-28 w-28"
                    />
                  </div>

                  <div class="flex flex-1 flex-col gap-2 p-4">
                    <h2 class="font-serif text-base font-bold leading-snug text-primary">
                      {toTitleCase(doc.title)}
                    </h2>
                    <span
                      class={`inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ${
                        isRegulation
                          ? "bg-primary/10 text-primary"
                          : "bg-secondary/15 text-secondary"
                      }`}
                    >
                      {doc.type}
                    </span>

                    <div class="mt-auto flex items-center gap-2 pt-3">
                      {fileUrl ? (
                        <>
                          <a
                            href={fileUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`View ${doc.title}`}
                            title="View"
                            class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-sm font-medium text-foreground transition-colors hover:border-accent hover:text-accent"
                          >
                            <Icon name="lucide:external-link" class="h-4 w-4" />
                            <span>View</span>
                          </a>
                          <a
                            href={fileUrl}
                            download
                            aria-label={`Download ${doc.title}`}
                            title="Download"
                            class="inline-flex items-center gap-1.5 rounded-md bg-accent px-3 py-2 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent-hover"
                          >
                            <Icon name="lucide:download" class="h-4 w-4" />
                            <span>Download</span>
                          </a>
                        </>
                      ) : (
                        <span class="text-xs text-muted-foreground">
                          File unavailable
                        </span>
                      )}
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        )
      }

      {
        pagination && pagination.pageCount > 1 && (
          <nav
            class="mt-10 flex items-center justify-between gap-4"
            aria-label="Pagination"
          >
            {hasPrev ? (
              <a
                href={linkParams(page - 1)}
                class="inline-flex items-center gap-1.5 rounded-md border border-border px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-accent hover:text-accent"
              >
                <Icon name="lucide:chevron-left" class="h-4 w-4" /> Previous
              </a>
            ) : (
              <span class="inline-flex items-center gap-1.5 rounded-md border border-border px-4 py-2 text-sm font-medium text-muted-foreground/50">
                <Icon name="lucide:chevron-left" class="h-4 w-4" /> Previous
              </span>
            )}

            <span class="text-sm text-muted-foreground">
              Page {pagination.page} of {pagination.pageCount}
            </span>

            {hasNext ? (
              <a
                href={linkParams(page + 1)}
                class="inline-flex items-center gap-1.5 rounded-md border border-border px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-accent hover:text-accent"
              >
                Next <Icon name="lucide:chevron-right" class="h-4 w-4" />
              </a>
            ) : (
              <span class="inline-flex items-center gap-1.5 rounded-md border border-border px-4 py-2 text-sm font-medium text-muted-foreground/50">
                Next <Icon name="lucide:chevron-right" class="h-4 w-4" />
              </span>
            )}
          </nav>
        )
      }
    </div>
  </section>
</BaseLayout>
